{
  "name": "pbhandover",
  "version": "0.1.1",
  "description": "Non-blocking Stop hook that keeps a shared HANDOVER.md up to date for both Claude Code and Codex CLI.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hiroshi-tamura/pbhandover.git"
  },
  "homepage": "https://github.com/hiroshi-tamura/pbhandover#readme",
  "bugs": {
    "url": "https://github.com/hiroshi-tamura/pbhandover/issues"
  },
  "bin": {
    "pbhandover": "bin/pbhandover.js"
  },
  "files": [
    "bin/",
    "src/",
    "test/",
    "templates/",
    "prompts/",
    "commands/",
    "README.md",
    "README.ja.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "postinstall": "node -e \"try{require('./src/postinstall')}catch(e){console.warn('[pbhandover] postinstall setup skipped: '+(e&&e.message?e.message:e))}\"",
    "test": "node --test",
    "smoke": "node bin/pbhandover.js --help"
  },
  "keywords": [
    "claude",
    "claude-code",
    "codex",
    "codex-cli",
    "hooks",
    "handover",
    "automation"
  ]
}
